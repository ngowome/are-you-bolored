        // Configuration du moteur de recherche Fuse.js
        const optionsRecherche = {
            includeScore: true,
            threshold: 0.3, // Tolérance aux fautes de frappe (0 = strict, 1 = très permissif)
            keys: ['n', 'aliases'] // On cherche dans le nom officiel et dans les alias
        };
        const moteurDeRecherche = new Fuse(baseDeDonnees, optionsRecherche);

        function lancerRecherche() {
            const saisie = document.getElementById("barreRecherche").value.trim();
            const zoneResultat = document.getElementById("zoneResultat");
            
            // On ne fait rien si le champ est vide
            if (!saisie) return;

            // On rend la zone visible
            zoneResultat.classList.remove("hidden");

            // Exécution de la recherche
            const resultats = moteurDeRecherche.search(saisie);

            if (resultats.length > 0) {
                // Si on trouve quelque chose, on prend le résultat le plus pertinent
                const cible = resultats[0].item;
                
                // Cas spécifique pour OCB ou les jeux revendus
                if (cible.type === "historique_revendu") {
                    zoneResultat.className = "mt-10 text-left p-6 md:p-8 rounded-2xl shadow-lg border-l-8 border-yellow-500 bg-yellow-50";
                    zoneResultat.innerHTML = `
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-3xl">⏳</span>
                            <h2 class="text-2xl font-bold text-yellow-800">Un fantôme du passé !</h2>
                        </div>
                        <p class="text-lg mb-2">Vous avez cherché <strong>${cible.n}</strong>.</p>
                        <p class="text-slate-700 mb-6">${cible.description}</p>
                        <div class="bg-white p-4 rounded-lg border border-yellow-200">
                            <p class="text-sm text-yellow-800 font-semibold uppercase tracking-wider mb-2">Chaîne historique</p>
                            <p class="font-medium text-slate-800">${cible.chain.join(" ➔ ")}</p>
                        </div>
                    `;
                } else {
                    // Cas classique "Bolloré'd"
                    zoneResultat.className = "mt-10 text-left p-6 md:p-8 rounded-2xl shadow-lg border-l-8 border-red-600 bg-red-50";
                    zoneResultat.innerHTML = `
                        <div class="flex items-center gap-3 mb-4">
                            <span class="text-3xl">🚨</span>
                            <h2 class="text-2xl font-bold text-red-700">Oui ! Vous êtes Bolloré'd.</h2>
                        </div>
                        <p class="text-lg mb-2">L'entité <strong>${cible.n}</strong> fait bien partie du groupe.</p>
                        <p class="text-slate-700 mb-6">${cible.description}</p>
                        <div class="bg-white p-4 rounded-lg border border-red-200 shadow-sm">
                            <p class="text-sm text-red-700 font-semibold uppercase tracking-wider mb-2">Chaîne de contrôle</p>
                            <p class="font-medium text-slate-800">${cible.chain.join(" ➔ ")}</p>
                        </div>
                    `;
                }
            } else {
                // Si aucun résultat
                zoneResultat.className = "mt-10 text-left p-6 md:p-8 rounded-2xl shadow-lg border-l-8 border-emerald-500 bg-emerald-50";
                zoneResultat.innerHTML = `
                    <div class="flex items-center gap-3 mb-4">
                        <span class="text-3xl">✅</span>
                        <h2 class="text-2xl font-bold text-emerald-800">A priori non !</h2>
                    </div>
                    <p class="text-lg text-emerald-900">Nous n'avons trouvé aucun lien direct entre <strong>"${saisie}"</strong> et l'empire Bolloré dans notre base de données.</p>
                    <p class="text-sm mt-4 text-emerald-700 italic">Attention, cette base n'est pas exhaustive et l'empire évolue constamment.</p>
                `;
            }
        }

        function gererToucheEntree(event) {
            if (event.key === "Enter") {
                lancerRecherche();
            }
        }
    </script>
